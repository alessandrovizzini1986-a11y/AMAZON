# Connessione PostgreSQL (locale, Supabase o altro provider)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/fleet?schema=public"

# Segreto per la firma dei JWT di sessione (generare con: openssl rand -base64 32)
AUTH_SECRET="change-me-generate-a-random-secret"

# Password iniziale dell'utente admin creato dal seed (solo demo)
SEED_ADMIN_PASSWORD="admin1234"

# Modalità accesso libero (SOLO per pilot in solitaria, mai in produzione con
# più utenti): se "true", salta login/cookie e agisce sempre come l'utente
# indicato sotto. Con questa attiva l'app è raggiungibile da chiunque abbia
# l'URL, senza credenziali. Lasciare non impostata per il funzionamento normale.
# AUTH_BYPASS="true"
# AUTH_BYPASS_EMAIL="admin@fleetdsp.demo"
