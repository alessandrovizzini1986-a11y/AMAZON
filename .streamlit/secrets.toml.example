# Copia questo file in `secrets.toml` (stessa cartella) e NON committarlo.
# In locale puoi anche lasciarlo vuoto: senza database_url l'app usa SQLite.

# Password per proteggere l'accesso online (obbligatoria prima di pubblicare).
app_password = "scegli-una-password-forte"

# Connessione Postgres per il deploy online (es. Neon).
# Se assente, l'app usa SQLite locale. Su Streamlit Cloud incolla qui la
# stringa di connessione di Neon (deve contenere ?sslmode=require).
# database_url = "postgresql://utente:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"
